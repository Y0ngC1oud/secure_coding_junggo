# 이 파일을 .env로 복사해서 사용하세요: cp .env.example .env
# 아래 값들은 그대로 두어도 바로 동작합니다. 꼭 바꿔야 하는 건 ADMIN_PASSWORD 하나뿐입니다.

SECRET_KEY=53a8b5515a797856087b3f3c091bd9aa99a221757574cff7ab995978e731108c
SESSION_COOKIE_SECURE=false
FLASK_DEBUG=false

# 서버 시작 시마다 아래 계정이 자동으로 관리자로 생성/동기화됩니다.
# (이미 있는 계정이면 비밀번호와 권한이 아래 값으로 항상 덮어써짐 — CLI 명령을 따로 실행할 필요 없음)
ADMIN_USERNAME=admin
# ↓ 원하는 비밀번호로 바꿔서 사용하세요 (이 값이 곧 관리자 로그인 비밀번호입니다)
ADMIN_PASSWORD=admin1234
ADMIN_NICKNAME=관리자
